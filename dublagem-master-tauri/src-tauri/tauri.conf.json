{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dublagem Master",
  "version": "0.1.0",
  "identifier": "com.dublagem.master",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "features": ["cuda"]
  },
  "app": {
    "windows": [
      {
        "title": "Dublagem Master",
        "width": 1360,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/audio-preview/**"]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
